# --- TELEGRAM BOT CONFIG ---
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
ADMIN_ID=000000000
WEBAPP_URL=https://senu-mentor-app.vercel.app
API_HOST=0.0.0.0
API_PORT=8080
INTERNAL_API_TOKEN=change-me

# --- DATABASE ---
# Вариант 1 (рекомендовано): готовый DSN
# DB_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Alembic (синхронный URL, без +asyncpg); можно не задавать — возьмётся из DB_URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Вариант 2: отдельные поля (бот сам соберет URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=senu_bot
DB_USER=postgres
DB_PASSWORD=postgres
# Опционально: require / prefer / disable
# DB_SSLMODE=require

# --- OPTIONAL ---
MENTOR_PHOTO_URL=https://example.com/photo.jpg
